{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent-validation.json schema",
  "type": "object",
  "required": ["timestamp", "results"],
  "properties": {
    "timestamp": { "type": "string" },
    "agents_validated": { "type": "integer" },
    "agents_passed": { "type": "integer" },
    "agents_with_warnings": { "type": "integer" },
    "agents_failed": { "type": "integer" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "file", "valid"],
        "properties": {
          "agent": { "type": "string" },
          "file": { "type": "string" },
          "valid": { "type": "boolean" },
          "checks": { "type": "object" },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "errors": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
