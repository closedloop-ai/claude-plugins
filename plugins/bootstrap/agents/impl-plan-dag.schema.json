{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://astoria-service.com/schemas/impl-plan-dag.schema.json",
  "title": "Implementation Plan DAG Schema",
  "description": "Schema for impl-plan.json workflow configuration with phase/stage pattern",
  "type": "object",
  "required": ["version", "workflow", "description", "phases", "metadata"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["1.0", "2.0"]
    },
    "workflow": {
      "type": "string",
      "description": "Workflow identifier",
      "const": "impl-plan"
    },
    "description": {
      "type": "string",
      "description": "Human-readable workflow description",
      "minLength": 10
    },
    "phases": {
      "type": "array",
      "description": "Ordered list of workflow phases",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/phase"
      }
    },
    "metadata": {
      "$ref": "#/definitions/metadata"
    },
    "defaults": {
      "type": "object",
      "description": "Default configuration values",
      "properties": {
        "parity": {
          "type": "string",
          "enum": ["auto", "strict", "none"]
        },
        "platform": {
          "type": "string",
          "enum": ["all", "mobile", "web"]
        },
        "scope": {
          "type": "string",
          "enum": ["repo", "feature", "file"]
        }
      }
    },
    "collaboration_matrix": {
      "type": "object",
      "description": "Agent collaboration dependencies (optional)"
    },
    "constraint_enforcement": {
      "type": "object",
      "description": "Validation constraints (optional)"
    }
  },
  "definitions": {
    "phase": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique phase identifier",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$",
          "examples": ["prd-analysis", "feature-location", "architecture", "cross-cutting"]
        },
        "description": {
          "type": "string",
          "description": "Human-readable phase description",
          "minLength": 10
        },
        "dependsOn": {
          "type": "array",
          "description": "List of phase names this phase depends on. This phase will wait for COMPLETE execution of all listed phases, including all stages within multi-stage phases. Example: if Phase B dependsOn Phase A, and Phase A has stages S1→S2, then Phase B waits for both S1 and S2 to complete.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "parallelizable": {
          "type": "boolean",
          "description": "Whether agents in this phase can run in parallel",
          "default": false
        },
        "orchestratorHandled": {
          "type": "boolean",
          "description": "Whether this phase is handled directly by the orchestrator (no agents listed)",
          "default": false
        },
        "requires": {
          "type": "array",
          "description": "List of input artifacts required for orchestrator-handled phases",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "produces": {
          "type": "array",
          "description": "List of output artifacts produced by orchestrator-handled phases",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "array",
          "description": "Additional notes about the phase",
          "items": {
            "type": "string"
          }
        },
        "agents": {
          "type": "array",
          "description": "Simple agent list (for phases without stages)",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "description": "Agent name reference (for simple universal agents)"
              },
              {
                "$ref": "#/definitions/agent"
              }
            ]
          },
          "minItems": 1
        },
        "stages": {
          "type": "array",
          "description": "Nested stages within this phase (for complex architecture phases)",
          "items": {
            "$ref": "#/definitions/stage"
          },
          "minItems": 1
        }
      }
    },
    "stage": {
      "type": "object",
      "required": ["name", "agents"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique stage identifier within phase",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$",
          "examples": ["foundation", "core-base", "core-derived", "supporting-base"]
        },
        "description": {
          "type": "string",
          "description": "Human-readable stage description"
        },
        "dependsOn": {
          "type": "array",
          "description": "List of stage names this stage depends on (within same phase)",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "parallelizable": {
          "type": "boolean",
          "description": "Whether agents in this stage can run in parallel",
          "default": true
        },
        "agents": {
          "type": "array",
          "description": "List of agents in this stage",
          "items": {
            "$ref": "#/definitions/agent"
          },
          "minItems": 1
        }
      }
    },
    "agent": {
      "type": "object",
      "required": ["name", "description", "requires", "produces"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique agent identifier",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$",
          "examples": ["react-component-architect", "database-architect", "test-strategist"]
        },
        "description": {
          "type": "string",
          "description": "Human-readable agent description with domain expertise",
          "minLength": 10
        },
        "priority": {
          "type": "integer",
          "description": "Execution priority (0=critical, 1=normal, 2=optional)",
          "minimum": 0,
          "maximum": 2,
          "default": 1
        },
        "color": {
          "type": "string",
          "description": "Visual color indicator for UI/reporting",
          "enum": ["red", "orange", "yellow", "green", "blue", "cyan", "purple", "pink"],
          "default": "blue"
        },
        "requires": {
          "type": "array",
          "description": "List of input artifacts this agent requires",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-_/*]+(?:\\.[a-z0-9]+)+$",
            "examples": [
              "requirements.json",
              "code-map.json",
              "arch/components.md",
              "reviews/*.review.json"
            ]
          },
          "uniqueItems": true
        },
        "produces": {
          "type": "array",
          "description": "List of output artifacts this agent produces",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-_/*]+(?:\\.[a-z0-9]+)+$",
            "examples": [
              "arch/components.md",
              "test-plan.md",
              "implementation-plan.md",
              "reviews/*.review.json"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "optional": {
          "type": "boolean",
          "description": "Whether this agent is optional",
          "default": false
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generatedBy", "timestamp", "totalAgents"],
      "additionalProperties": false,
      "properties": {
        "generatedBy": {
          "type": "string",
          "description": "Tool that generated this DAG",
          "enum": ["agent-bootstrap", "manual"],
          "default": "agent-bootstrap"
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp of generation",
          "format": "date-time",
          "examples": ["2025-10-20T17:15:27Z"]
        },
        "totalAgents": {
          "type": "integer",
          "description": "Total number of agents in workflow",
          "minimum": 1
        },
        "bootstrapVersion": {
          "type": "string",
          "description": "Bootstrap system version (optional)",
          "pattern": "^\\d+\\.\\d+$",
          "examples": ["1.0", "2.0"]
        },
        "maxParallelism": {
          "type": "integer",
          "description": "Maximum concurrent agents allowed",
          "minimum": 1,
          "maximum": 20,
          "default": 5
        },
        "corrections": {
          "type": "array",
          "description": "List of auto-corrections applied during generation",
          "items": {
            "type": "string"
          }
        },
        "validationStatus": {
          "type": "string",
          "description": "Validation result status",
          "enum": ["passed", "corrected", "failed"]
        },
        "notes": {
          "type": "array",
          "description": "Additional notes about the workflow",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
