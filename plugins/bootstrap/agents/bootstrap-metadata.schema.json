{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": ".bootstrap-metadata.json schema",
  "type": "object",
  "required": ["bootstrap_version", "last_run", "agents"],
  "properties": {
    "bootstrap_version": { "type": "string" },
    "last_run": { "type": "string" },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["generated"],
        "properties": {
          "generated": { "type": "string" },
          "domain": { "type": "string" },
          "specialization": { "type": "object" },
          "generation_hash": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
